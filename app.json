{
  "expo": {
    "name": "FluentBee",
    "slug": "fluentbee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fluentbee",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0F1210"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.irissalgado.fluentbee",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.irissalgado.fluentbee",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1E7214"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1E7214",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "e71517fa-fc0e-47e2-8a84-5c4a3bbffc1a"
      },
      "router": {}
    },
    "owner": "iris417"
  }
}
