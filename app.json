{
  "expo": {
    "name": "BeeFluent",
    "slug": "beefluent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "beefluent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0F1210"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.irissalgado.beefluent",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.beefluent.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
